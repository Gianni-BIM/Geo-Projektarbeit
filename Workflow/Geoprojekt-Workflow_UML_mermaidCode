graph LR
    %% Styles
    classDef start_end fill:#f96,stroke:#333,stroke-width:2px;
    classDef process fill:#fff,stroke:#333,stroke-width:1px;
    classDef decision fill:#fff,stroke:#333,stroke-width:2px;
    classDef data fill:#e1f5fe,stroke:#01579b,stroke-width:1px;

    %% Workflow
    START((Start)):::start_end --> CSV[/points.csv & legend.txt/]:::data
    
    subgraph "1. Datenaufbereitung & Cleaning"
        CSV --> CLEAN1[Ausschluss technischer Spalten <br/>ID, X, Y, lon, lat]:::process
        CLEAN1 --> HOBLEY{Hobley-Regel: <br/>Klasse n < 30?}:::decision
        HOBLEY -- Ja --> DROP[Kategorie entfernen]:::process
        DROP --> HOBLEY
        HOBLEY -- Nein --> MAP[Mapping Klimanamen]:::process
        MAP --> ENCODE[One-Hot-Encoding <br/>Kategoriale Prädiktoren]:::process
    end

    subgraph "2. EDA & Feature Selection"
        ENCODE --> CORR[Korrelationsanalyse <br/>height, temp, rain]:::process
        CORR --> DIST[SHI-Verteilung <br/>Histogramme & Boxplots]:::process
    end

    subgraph "3. Modell-Optimierung (Tuning)"
        DIST --> GRID[Parameter-Grid definieren <br/>ntree, mtry, split, bucket]:::process
        GRID --> SEARCH[Grid Search mit <br/>OOB-Validierung]:::process
        SEARCH --> BEST{OOB R² <br/>maximiert?}:::decision
        BEST -- Nein --> GRID
        BEST -- Ja --> PARAMS[Beste Hyperparameter <br/>fixieren]:::process
    end

    subgraph "4. Training & Evaluation"
        PARAMS --> RF[Finaler RF-Regressor <br/>500 Bäume]:::process
        RF --> METRICS[Berechnung OOB-Metriken <br/>R²: 0.401, RMSE: 0.346]:::process
        METRICS --> RESID[Residuenanalyse]:::process
    end

    subgraph "5. Interpretation"
        RESID --> IMP[Permutation Feature Importance]:::process
        IMP --> PDP[Partial Dependence Plots <br/>Einflussrichtungen]:::process
        PDP --> TREE[Extraktion Repräsentativer Baum <br/>max_depth=3]:::process
    end

    TREE --> END((Ergebnisse & <br/>Dokumentation)):::start_end

